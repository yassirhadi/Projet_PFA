# ==================================================
# Environment Variables Template
# ==================================================
# Copy this file to .env and fill with real values
# DO NOT commit .env to Git!
#
# Spring Boot lit directement les variables d’environnement du système.
# Pour charger un fichier .env automatiquement, utilisez votre IDE ou un outil dédié.

# Profil actif (dev ou prod) — Spring accepte aussi SPRING_PROFILES_ACTIVE
SPRING_PROFILES_ACTIVE=dev

# Server
SERVER_PORT=8080

# MySQL (profil dev — valeurs par défaut aussi dans application-dev.properties)
DB_URL=jdbc:mysql://localhost:3306/cv_platform?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_256_bits_minimum_here

# File Upload
UPLOAD_DIR=uploads

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Production (SPRING_PROFILE=prod) : DB_URL, DB_USERNAME, DB_PASSWORD sont obligatoires
